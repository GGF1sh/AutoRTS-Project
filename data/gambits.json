		{ "cond": "ally_hp_below", "param": 0.7, "action": "heal_lowest_hp_ally" },
		{ "cond": "enemy_in_range", "action": "attack_nearest" },
		{ "cond": "nearest_enemy_exists", "action": "move_to_nearest_enemy" }
