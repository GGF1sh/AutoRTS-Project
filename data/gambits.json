		{ "cond": "self_hp_below", "param": 0.3, "action": "retreat_to_safe", "factor": 1.2 },
		{ "cond": "enemy_in_range", "action": "attack_weakest" },
		{ "cond": "nearest_enemy_exists", "action": "move_to_nearest_enemy" }
	],
